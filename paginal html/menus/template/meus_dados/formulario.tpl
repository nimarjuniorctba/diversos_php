<header class="topbar"><button class="icon-button mobile-menu-button" id="mobileMenuButton" type="button" aria-label="Abrir menu" aria-controls="sidebar"><svg viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg></button><div><p class="eyebrow">Configurações</p><h1>Meus dados</h1></div></header>
<section class="page-body clients-page">{if !empty($mensagem)}<div class="alert alert--success clients-message"><span class="alert__icon">✓</span><div><strong>Tudo certo!</strong><p>{$mensagem.texto}</p></div></div>{/if}
<form method="post" class="client-form"><input type="hidden" name="csrf_token" value="{$csrf_token}"><input type="hidden" name="sis_id" value="{$sistema.id}">
<article class="form-card client-form-card"><div class="form-card__header"><div><p class="eyebrow">Identidade</p><h2>Dados do sistema</h2></div></div><div class="sample-form client-form-grid">
<div class="form-field"><label>CNPJ</label><input name="sis_cnpj" data-mask="cnpj" value="{$sistema.cnpj|escape}"></div><div class="form-field"><label>Nome fantasia</label><input name="sis_nome_fantasia" value="{$sistema.fantasia|escape}"></div><div class="form-field form-field--full"><label>Razão social</label><input name="sis_razao" value="{$sistema.razao|escape}"></div><div class="form-field"><label>Inscrição estadual</label><input name="sis_ie" value="{$sistema.ie|escape}"></div><label class="checkbox-field"><input type="checkbox" name="sis_ie_isento" {if $sistema.isento==='s'}checked{/if}><span>Isento</span></label><div class="form-field form-field--full"><label>Responsável</label><input name="sis_responsavel" value="{$sistema.responsavel|escape}"></div></div></article>
<article class="form-card client-form-card"><div class="form-card__header"><div><h2>Endereço</h2></div></div><div class="sample-form client-form-grid"><div class="form-field"><label>CEP</label><input name="sis_cep" data-mask="cep" value="{$sistema.cep|escape}"></div><div class="form-field"><label>Rua</label><input name="sis_rua" value="{$sistema.rua|escape}"></div><div class="form-field"><label>Número</label><input name="sis_numero" value="{$sistema.numero|escape}"></div><div class="form-field"><label>Complemento</label><input name="sis_complemento" value="{$sistema.complemento|escape}"></div><div class="form-field"><label>Bairro</label><input name="sis_bairro" value="{$sistema.bairro|escape}"></div><div class="form-field"><label>Cidade</label><input name="sis_cidade" value="{$sistema.cidade|escape}"></div><div class="form-field"><label>Estado</label><input name="sis_estado" maxlength="2" class="uppercase-input" value="{$sistema.estado|escape}"></div></div></article>
<article class="form-card client-form-card"><div class="form-card__header"><div><h2>Contato</h2></div></div><div class="sample-form client-form-grid"><div class="form-field"><label>Telefone</label><input name="sis_telefone" data-mask="phone" value="{$sistema.telefone|escape}"></div><div class="form-field"><label>Celular</label><input name="sis_celular" data-mask="phone" value="{$sistema.celular|escape}"></div><div class="form-field"><label>WhatsApp</label><input name="sis_whatsapp" data-mask="phone" value="{$sistema.whatsapp|escape}"></div><div class="form-field"><label>E-mail</label><input type="email" name="sis_email" value="{$sistema.email|escape}"></div><div class="form-field"><label>Facebook</label><input name="sis_facebook" value="{$sistema.facebook|escape}"></div><div class="form-field"><label>Instagram</label><input name="sis_instagram" value="{$sistema.instagram|escape}"></div></div></article>
<div class="client-form-actions"><button class="primary-button" type="submit">Salvar meus dados</button></div></form></section>
